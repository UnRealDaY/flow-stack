APP_NAME=FlowStack-Payment
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

LOG_CHANNEL=stack
LOG_LEVEL=debug

# PostgreSQL — same instance as core-api
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=flowstack
DB_USERNAME=flowstack
DB_PASSWORD=flowstack

# Redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=flowstack
REDIS_PORT=6379

# Queue / Cache
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# Stripe
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_PRO=price_
STRIPE_PRICE_ENTERPRISE=price_
