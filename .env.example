# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=flowstack
POSTGRES_PASSWORD=flowstack
POSTGRES_DB=flowstack
POSTGRES_PORT=5432
DATABASE_URL=postgresql://flowstack:flowstack@localhost:5432/flowstack

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=flowstack
REDIS_PORT=6379
REDIS_URL=redis://:flowstack@localhost:6379

# ─── S3 / MinIO ──────────────────────────────────────────────────────────────
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=flowstack
S3_BUCKET=flowstack
S3_ENDPOINT=http://localhost:9000
S3_PORT=9000
S3_REGION=us-east-1
MINIO_CONSOLE_PORT=9001

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Services — ports ────────────────────────────────────────────────────────
CORE_API_PORT=4000
REALTIME_PORT=4001
FILE_SERVICE_PORT=8000
PAYMENT_PORT=8001

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4001
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email ───────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@flowstack.dev

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
